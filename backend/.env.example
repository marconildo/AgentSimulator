# ---------------------------------------------------------------------------
# AI Agent Simulator — backend configuration
#
# Copy this file to `.env` and fill in the values you need.
# The app runs in two modes:
#   - DEMO_MODE=true  -> deterministic mock LLM + mock embeddings, NO API key
#                        needed. Great for screenshots, CI and first run.
#   - DEMO_MODE=false -> real OpenAI calls (requires OPENAI_API_KEY, spends
#                        tokens). This is the "real engineering" path.
#
# If DEMO_MODE is unset, the app auto-detects: it uses OpenAI when
# OPENAI_API_KEY is present, otherwise it falls back to demo mode.
# ---------------------------------------------------------------------------

# Leave empty to run fully offline in demo mode.
OPENAI_API_KEY=

# Force a mode (true/false). Comment out to auto-detect from OPENAI_API_KEY.
# DEMO_MODE=true

# Models (only used when DEMO_MODE=false)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# RAG settings
RAG_TOP_K=4
CHROMA_DIR=app/data/chroma
CORPUS_DIR=app/data/corpus

# CORS — comma separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
