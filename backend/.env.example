# ---------------------------------------------------------------------------
# AI Agent Simulator — backend configuration
#
# Copy this file to `.env` and fill in the values you need.
#
# The app runs ONLY against OpenAI — there is no offline/demo mode. An
# OPENAI_API_KEY is REQUIRED: with no key the app fails fast at startup and the
# /api/chat endpoint returns a clear error. Running it spends OpenAI tokens.
# ---------------------------------------------------------------------------

# Required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: web search (Tavily). Enables the `web_search` MCP tool — a real
# internet search. NOT required: with no key the tool returns an honest error
# string and the rest of the app runs unchanged. Get one at https://tavily.com
TAVILY_API_KEY=

# RAG settings
RAG_TOP_K=4
CHROMA_DIR=app/data/chroma
CORPUS_DIR=app/data/corpus

# Object storage — durable store uploaded documents land in before indexing
# (a local filesystem stand-in for Blob/S3; a mounted volume in Docker)
STORAGE_DIR=app/data/storage

# CORS — comma separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Optional: LangSmith tracing
#
# The agent runs on LangGraph + langchain-openai, both of which LangSmith
# auto-traces. These keys are read straight from the environment; the app loads
# this whole `.env` into os.environ at startup so they take effect here. Leave
# LANGSMITH_TRACING unset (or false) to keep tracing off.
# ---------------------------------------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=agent-simulator
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
